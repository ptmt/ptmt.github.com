<div data-lang-scope>
    <div class="home-layout">
        <div class="home-left-column">
            <section class="latest-posts">
                <table class="post-file-list">
                    <thead>
                        <tr>
                            <th scope="col">Name</th>
                            <th scope="col">Size</th>
                            <th scope="col">Date Added</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each posts}}
                        {{#if (eq metadata.lang "en")}}
                        <tr data-post-lang="{{metadata.lang}}">
                            <td class="post-file-name"><a href="/{{path}}">{{title}}</a></td>
                            <td class="post-file-size" data-size-url="/{{path}}" data-size-bytes="{{content.length}}">--</td>
                            <td class="post-file-date"><time datetime="{{date}}">{{formatDate date "yyyy-MM-dd"}}</time></td>
                        </tr>
                        {{/if}}
                        {{/each}}
                    </tbody>
                </table>
            </section>

            <section class="ideas">
                <h2 class="section-title"><a href="/garage/">Garage</a></h2>
                <div class="garage-logos-grid">
                    {{#with datasource}}
                    {{#each entities.garage}}
                        {{#unless metadata.hidden}}
                        <div class="garage-logo-item">
                            <a href="{{source.path}}" class="garage-logo-link">
                                {{#if metadata.logo}}
                                <img src="{{metadata.logo}}" class="garage-logo" alt="" aria-hidden="true" />
                                {{else}}
                                    {{#if metadata.image}}
                                    <img src="{{metadata.image}}" class="garage-logo" alt="" aria-hidden="true" />
                                    {{else}}
                                    <span class="garage-logo-name">{{title}}</span>
                                    {{/if}}
                                {{/if}}
                            </a>
                            {{#if metadata.summary}}
                            <p class="garage-logo-summary">{{metadata.summary}}</p>
                            {{/if}}
                        </div>
                        {{/unless}}
                    {{/each}}
                    {{/with}}
                </div>
            </section>
        </div>
    </div>
</div>
{{#content "right-column"}}
    <div class="home-right-column">
        <section class="random-image-section">
            <div id="random-image" class="skeleton" aria-busy="true">
                <div class="image-source"></div>
            </div>
        </section>

        <section class="random-quote-section">
            <div id="random-quote" class="skeleton" aria-busy="true">
                <div class="quote-text"></div>
                <div class="quote-author"></div>
                <div class="quote-source"></div>
            </div>
        </section>

        {{include "partials/footer.hbs"}}
    </div>
{{/content}}

{{#content "footer"}}{{/content}}

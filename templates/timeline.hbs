<article>
    <h1>{{post.title}}</h1>
    {{#if post.metadata.description}}
    <p class="post-subtitle">
        {{post.metadata.description}}
    </p>
    {{/if}}
    <time datetime="{{post.date}}">{{formatDate post.date "MMMM d, yyyy"}}</time>

    {{#if post.content}}
    <div class="content">
        {{{post.content}}}
    </div>
    {{/if}}
</article>

<noscript>
    <style>
        .timeline-section {
            display: block !important;
            margin-bottom: var(--spacing-xl);
        }
    </style>
</noscript>

<div class="timeline-layout" data-focus-from="{{#if post.metadata.timelineFocusFrom}}{{post.metadata.timelineFocusFrom}}{{else}}1{{/if}}">
    <div class="timeline-content">
        {{#each post.metadata.timeline}}
        <section id="{{id}}" class="timeline-section{{#unless @first}} timeline-section--focus{{/unless}}">
            <figure>
                <div class="caption-header">
                    <span class="timeline-id-tag tag">{{id}}</span>
                </div>
                <div class="figure-content">
                    {{#if img}}
                    <img src="{{img}}" alt="{{#if alt}}{{alt}}{{else}}{{captionTitle}}{{/if}}">
                    {{/if}}
                    <figcaption class="caption-text">
                        {{{md captionText}}}
                    </figcaption>
                </div>
            </figure>
            <div class="timeline-section-nav">
                {{#unless @first}}
                <button type="button" class="timeline-prev-button timeline-nav-button">← Prev</button>
                {{/unless}}
                {{#unless @last}}
                <button type="button" class="timeline-next-button timeline-nav-button">Next →</button>
                {{/unless}}
            </div>
        </section>
        {{/each}}
    </div>

    <nav class="timeline-nav">
        {{#each post.metadata.timeline}}
        <a href="#{{id}}" class="timeline-milestone">{{id}}</a>
        {{/each}}
    </nav>
</div>


<script>
(function() {
    'use strict';

    const layout = document.querySelector('.timeline-layout');
    const sections = Array.from(document.querySelectorAll('.timeline-section'));
    const milestones = Array.from(document.querySelectorAll('.timeline-milestone'));

    if (sections.length === 0 || milestones.length === 0) return;

    const sectionIds = sections.map(s => s.id);
    const focusFromIndex = layout
        ? Math.max(0, parseInt(layout.dataset.focusFrom, 10) || 1)
        : 1;

    function isFocusSection(sectionId) {
        const idx = sectionIds.indexOf(sectionId);
        return idx >= focusFromIndex;
    }

    function setFocusMode(sectionId) {
        document.body.classList.toggle('timeline-focus-mode', isFocusSection(sectionId));
    }

    function removeActive() {
        milestones.forEach(m => m.classList.remove('active'));
        sections.forEach(s => s.classList.remove('active'));
    }

    function showSection(sectionId, updateHistory) {
        removeActive();
        const section = document.getElementById(sectionId);
        const milestone = document.querySelector('.timeline-milestone[href="#' + sectionId + '"]');

        if (section) section.classList.add('active');
        if (milestone) {
            milestone.classList.add('active');
            milestone.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
        }

        if (updateHistory !== false) {
            history.pushState({ sectionId: sectionId }, '', '#' + sectionId);
        }

        setFocusMode(sectionId);

        if (isFocusSection(sectionId)) {
            window.scrollTo({ top: 0, behavior: 'instant' });
        }
    }

    // Prevent default scroll behavior when page loads with hash
    if (window.location.hash) {
        window.scrollTo(0, 0);
    }

    // Init
    function initSection() {
        const hashId = window.location.hash ? decodeURIComponent(window.location.hash.substring(1)) : null;
        if (hashId && sectionIds.includes(hashId)) {
            showSection(hashId, false);
            // Scroll to top of the section after showing it
            if (!isFocusSection(hashId)) {
                setTimeout(() => {
                    const section = document.getElementById(hashId);
                    if (section) {
                        const rect = section.getBoundingClientRect();
                        const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
                        window.scrollTo({
                            top: scrollTop + rect.top - 20,
                            behavior: 'instant'
                        });
                    }
                }, 50);
            }
        } else {
            showSection(sectionIds[0], false);
        }
    }

    // Handle initial load - run immediately to prevent browser scroll
    initSection();

    milestones.forEach(milestone => {
        milestone.addEventListener('click', function(e) {
            e.preventDefault();
            const targetId = this.getAttribute('href').substring(1);
            showSection(targetId);
        });
    });

    function navigateSection(button, offset) {
        button.addEventListener('click', function(e) {
            e.preventDefault();
            const current = this.closest('.timeline-section');
            if (!current) return;
            const idx = sectionIds.indexOf(current.id);
            if (idx < 0) return;
            const targetId = sectionIds[idx + offset];
            if (targetId) showSection(targetId);
        });
    }

    document.querySelectorAll('.timeline-next-button').forEach(button => navigateSection(button, 1));
    document.querySelectorAll('.timeline-prev-button').forEach(button => navigateSection(button, -1));

    window.addEventListener('popstate', function(e) {
        if (e.state && e.state.sectionId) {
            showSection(e.state.sectionId, false);
        } else {
            // Handle browser back/forward with hash
            const hashId = window.location.hash ? decodeURIComponent(window.location.hash.substring(1)) : null;
            if (hashId && sectionIds.includes(hashId)) {
                showSection(hashId, false);
            }
        }
    });

    // Also handle hashchange events (e.g., when user manually changes URL)
    window.addEventListener('hashchange', function() {
        const hashId = window.location.hash ? decodeURIComponent(window.location.hash.substring(1)) : null;
        if (hashId && sectionIds.includes(hashId)) {
            showSection(hashId, false);
        }
    });
})();
</script>
